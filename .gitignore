# ---------------------------------------------------------------
# Visual Studio / C++ .gitignore
# Tracks: source (.cpp/.hpp), headers, resources, project files
# Ignores: build output, VS user/cache files, DLLs, binaries
# ---------------------------------------------------------------

# Visual Studio cache / user files
.vs/
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb

# Build output directories (any configuration, any platform)
[Dd]ebug/
[Rr]elease/
[Xx]64/
[Xx]86/
[Ww]in32/
[Bb]uild/
[Bb]in/
[Oo]bj/
ipch/

# Compiled object / intermediate files
*.obj
*.o
*.lib
*.a
*.exp
*.ilk
*.pdb
*.idb
*.tlog
*.log
*.recipe
*.lastbuildstate
*.unsuccessfulbuild
*.tlb
*.res
*.pch
*.ipch

# Executables and shared libraries
*.exe
*.out
*.app
*.dll
*.so
*.dylib

# Editor / OS cruft
.vscode/
*.swp
*~
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# CMake (in case it gets added later)
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
